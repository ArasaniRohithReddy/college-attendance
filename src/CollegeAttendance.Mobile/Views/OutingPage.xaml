<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CollegeAttendance.Mobile.ViewModels"
             x:Class="CollegeAttendance.Mobile.Views.OutingPage"
             x:DataType="vm:OutingViewModel"
             Title="Outing Requests"
             BackgroundColor="#F8FAFC">

    <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <!-- New Request Form (Students only) -->
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" 
                        Stroke="#E2E8F0" Padding="16" IsVisible="{Binding IsStudent}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="New Outing Request" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Purpose" FontSize="12" TextColor="#64748B"/>
                            <Entry Text="{Binding Purpose}" Placeholder="Reason for outing" 
                                   BackgroundColor="#F1F5F9" FontSize="14"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Destination" FontSize="12" TextColor="#64748B"/>
                            <Entry Text="{Binding Destination}" Placeholder="Where are you going?" 
                                   BackgroundColor="#F1F5F9" FontSize="14"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Out Date" FontSize="12" TextColor="#64748B"/>
                                <DatePicker Date="{Binding OutDate}" BackgroundColor="#F1F5F9" FontSize="14"
                                            MinimumDate="{x:Static sys:DateTime.Today}" 
                                            xmlns:sys="clr-namespace:System;assembly=netstandard"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Out Time" FontSize="12" TextColor="#64748B"/>
                                <TimePicker Time="{Binding OutTime}" BackgroundColor="#F1F5F9" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Return Date" FontSize="12" TextColor="#64748B"/>
                                <DatePicker Date="{Binding ReturnDate}" BackgroundColor="#F1F5F9" FontSize="14"
                                            MinimumDate="{x:Static sys:DateTime.Today}"
                                            xmlns:sys="clr-namespace:System;assembly=netstandard"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Return Time" FontSize="12" TextColor="#64748B"/>
                                <TimePicker Time="{Binding ReturnTime}" BackgroundColor="#F1F5F9" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Submit Request"
                                Command="{Binding SubmitRequestCommand}"
                                BackgroundColor="#6366F1"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="44"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Outing List -->
                <Label Text="Requests" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>

                <CollectionView ItemsSource="{Binding Outings}">
                    <CollectionView.EmptyView>
                        <Label Text="No outing requests" FontSize="14" TextColor="#94A3B8" 
                               HorizontalOptions="Center" Padding="24"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" 
                                    Stroke="#E2E8F0" Padding="14" Margin="0,4">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Purpose}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B"/>
                                        <Border Grid.Column="1" StrokeShape="RoundRectangle 6" Padding="8,4"
                                                BackgroundColor="#EEF2FF">
                                            <Label Text="{Binding StatusDisplay}" FontSize="11" TextColor="#6366F1"/>
                                        </Border>
                                    </Grid>
                                    <Label Text="{Binding Destination, StringFormat='To: {0}'}" FontSize="13" TextColor="#64748B"/>
                                    <Label FontSize="12" TextColor="#94A3B8">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding RequestedOutTime, StringFormat='{0:MMM dd HH:mm}'}"/>
                                                <Span Text=" → "/>
                                                <Span Text="{Binding ExpectedReturnTime, StringFormat='{0:MMM dd HH:mm}'}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
