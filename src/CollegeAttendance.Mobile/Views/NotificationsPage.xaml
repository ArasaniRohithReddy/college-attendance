<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CollegeAttendance.Mobile.ViewModels"
             x:Class="CollegeAttendance.Mobile.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Notifications"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">
        <!-- Header with Mark All Read -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto">
            <Label Text="Notifications" FontSize="20" FontAttributes="Bold" TextColor="#1E293B"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="Mark All Read"
                    Command="{Binding MarkAllReadCommand}"
                    BackgroundColor="Transparent" TextColor="#6366F1" FontSize="13"
                    Padding="8,4"/>
        </Grid>

        <!-- Notification List -->
        <RefreshView Grid.Row="1" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Notifications}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="24">
                        <Label Text="🔔" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No notifications" FontSize="16" TextColor="#94A3B8" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="14" Margin="16,4">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=MarkAsReadCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="8,*" ColumnSpacing="12">
                                <!-- Unread indicator -->
                                <BoxView Grid.Column="0" WidthRequest="8" HeightRequest="8"
                                         CornerRadius="4" BackgroundColor="#6366F1"
                                         IsVisible="{Binding IsRead, Converter={StaticResource InvertedBoolConverter}}"
                                         VerticalOptions="Start" Margin="0,6,0,0"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B"/>
                                    <Label Text="{Binding Message}" FontSize="13" TextColor="#64748B" MaxLines="2"/>
                                    <Label Text="{Binding TimeAgo}" FontSize="11" TextColor="#94A3B8"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
