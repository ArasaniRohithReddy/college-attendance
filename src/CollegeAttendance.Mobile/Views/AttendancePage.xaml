<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CollegeAttendance.Mobile.ViewModels"
             x:Class="CollegeAttendance.Mobile.Views.AttendancePage"
             x:DataType="vm:AttendanceViewModel"
             Title="My Attendance"
             BackgroundColor="#F8FAFC">

    <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <!-- Attendance Summary Card -->
                <Border StrokeShape="RoundRectangle 16" BackgroundColor="#6366F1" Padding="24">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Overall Attendance" FontSize="14" TextColor="#C7D2FE" HorizontalOptions="Center"/>
                        <Label Text="{Binding OverallPercentage, StringFormat='{0:F1}%'}" 
                               FontSize="48" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="{Binding Records.Count, StringFormat='{0} records'}" 
                               FontSize="12" TextColor="#C7D2FE" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Records List -->
                <Label Text="Recent Records" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>

                <CollectionView ItemsSource="{Binding Records}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="24">
                            <Label Text="No attendance records yet" FontSize="14" TextColor="#94A3B8" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" 
                                    Stroke="#E2E8F0" Padding="14" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Status indicator -->
                                    <BoxView Grid.Column="0" WidthRequest="4" CornerRadius="2" 
                                             VerticalOptions="Fill"
                                             Color="{Binding Status, Converter={StaticResource AttendanceStatusColorConverter}}"/>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding SessionTitle}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B"/>
                                        <Label Text="{Binding MarkedAt, StringFormat='{0:MMM dd, yyyy HH:mm}'}" FontSize="12" TextColor="#64748B"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Column="2" StrokeShape="RoundRectangle 6" Padding="8,4"
                                            VerticalOptions="Center"
                                            BackgroundColor="{Binding Status, Converter={StaticResource AttendanceStatusBgConverter}}">
                                        <Label Text="{Binding Status}" FontSize="11" 
                                               TextColor="{Binding Status, Converter={StaticResource AttendanceStatusColorConverter}}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
